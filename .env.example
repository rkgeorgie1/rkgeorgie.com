# PostgreSQL Database Connection String
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# --- OPTIONAL: Production examples ---
# Supabase:  DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Neon:      DATABASE_URL=postgresql://[user]:[password]@[host].neon.tech/[database]?sslmode=require
